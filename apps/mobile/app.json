{
  "expo": {
    "name": "YappChat",
    "slug": "yappchatt",
    "scheme": "yappchat",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wxperts.yappchat"
    },
    "android": {
      "package": "com.wxperts.yappchat",
      "edgeToEdgeEnabled": true
    },
    "extra": {
      "apiBaseUrl": "https://www.yappchatt.com",
      "eas": {
        "projectId": "755bfa8b-a1d3-4e48-a8cf-e2f6b1b3106a"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-asset"
    ],
    "owner": "wxperts-llc"
  }
}
