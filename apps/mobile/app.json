{
  "expo": {
    "name": "YappChat",
    "slug": "yappchatt",
    "scheme": "yappchat",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "backgroundColor": "#4F46E5",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wxperts.yappchat"
    },
    "android": {
      "package": "com.wxperts.yappchat",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      }
    },
    "extra": {
      "apiBaseUrl": "https://www.yappchatt.com",
      "eas": {
        "projectId": "755bfa8b-a1d3-4e48-a8cf-e2f6b1b3106a"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#4F46E5",
          "image": "./assets/splash-icon.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#312E81",
            "image": "./assets/splash-icon.png",
            "imageWidth": 240
          }
        }
      ]
    ],
    "owner": "wxperts-llc"
  }
}
